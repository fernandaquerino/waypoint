{
  "name": "waypoint",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "pnpm --filter @waypoint/db build && pnpm -r --parallel --filter @waypoint/api --filter @waypoint/web dev",
    "dev:web": "pnpm --filter @waypoint/web dev",
    "dev:api": "pnpm --filter @waypoint/api dev",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down --volumes --remove-orphans",
    "db:up": "docker compose up postgres",
    "db:generate": "drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config packages/db/drizzle.config.ts",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @waypoint/web build",
    "build:api": "pnpm --filter @waypoint/api build",
    "build:db": "pnpm --filter @waypoint/db build",
    "build:types": "pnpm --filter @waypoint/types build",
    "build:ui": "pnpm --filter @waypoint/ui build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm --filter @waypoint/db build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.63.0"
  }
}
